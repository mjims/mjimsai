# ============================================================
# MILA Open — Environment Variables
# ============================================================
# Copy to .env and fill in values before running docker compose up.

# --- Database ---
POSTGRES_USER=mila
POSTGRES_PASSWORD=REPLACE-ME-postgres-password
POSTGRES_DB=mila

# --- Auth ---
# Generate: openssl rand -base64 48
JWT_SECRET=REPLACE-ME-jwt-secret-min-32-chars
# Generate: openssl rand -hex 32
ADMIN_API_KEY=REPLACE-ME-admin-key

# --- LLM Providers (configure at least one) ---
# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-REPLACE-ME
# OpenAI (GPT-4o)
# OPENAI_API_KEY=sk-REPLACE-ME
# Google Gemini
# GOOGLE_API_KEY=REPLACE-ME
# xAI (Grok)
# XAI_API_KEY=xai-REPLACE-ME

# --- App ---
LOG_LEVEL=INFO
ENVIRONMENT=production
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
SAAS_MODE=true

# --- Ports ---
API_PORT=8080
DASHBOARD_PORT=3000

# --- Dashboard ---
NEXT_PUBLIC_API_URL=http://localhost:8080

# --- Observability (optional) ---
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
